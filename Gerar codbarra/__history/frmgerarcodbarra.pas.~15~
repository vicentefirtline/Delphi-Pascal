unit frmgerarcodbarra;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.StdCtrls, Vcl.Buttons,
  FireDAC.Stan.Intf, FireDAC.Stan.Option, FireDAC.Stan.Param,
  FireDAC.Stan.Error, FireDAC.DatS, FireDAC.Phys.Intf, FireDAC.DApt.Intf,
  FireDAC.Stan.Async, FireDAC.DApt, Data.DB, FireDAC.Comp.DataSet,
  FireDAC.Comp.Client, frxClass, frxDBSet, FireDAC.UI.Intf, FireDAC.Stan.Def,
  FireDAC.Stan.Pool, FireDAC.Phys, FireDAC.Phys.FB, FireDAC.Phys.FBDef,
  FireDAC.VCLUI.Wait, FireDAC.Phys.IBBase, FireDAC.Comp.UI, frxBarcode,
  Vcl.ComCtrls, Vcl.Grids, Vcl.DBGrids;

type
  TForm1 = class(TForm)
    imgcodbarra: TImage;
    edtcodarra: TEdit;
    Label1: TLabel;
    btngerarcodbarra: TBitBtn;
    btnSalvar: TBitBtn;
    frxReport1: TfrxReport;
    frxDBDataset1: TfrxDBDataset;
    qryPVFicha: TFDQuery;
    KeepingConnection: TFDConnection;
    FDGUIxWaitCursor1: TFDGUIxWaitCursor;
    FDPhysFBDriverLink1: TFDPhysFBDriverLink;
    qryinsereficha: TFDQuery;
    qryinserefichaCODIGO: TIntegerField;
    qryinserefichaCOD_FICHA: TStringField;
    qryinserefichaCODBARRAPV: TBlobField;
    frxBarCodeObject1: TfrxBarCodeObject;
    PageControl1: TPageControl;
    cadastro: TTabSheet;
    lista: TTabSheet;
    Panel1: TPanel;
    Label2: TLabel;
    bitbtnsair: TBitBtn;
    btnnovo: TBitBtn;
    btnreimprimir: TBitBtn;
    btnsair: TBitBtn;
    DBGrid1: TDBGrid;
    qryprevendaficha: TFDQuery;
    dsficha: TDataSource;
    qryprevendafichaCODIGO: TIntegerField;
    qryprevendafichaCOD_FICHA: TStringField;
    qryprevendafichaCODBARRAPV: TBlobField;
    procedure btngerarcodbarraClick(Sender: TObject);
    procedure btnSalvarClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure bitbtnsairClick(Sender: TObject);


  private
    { Private declarations }
    procedure GerarCodigo(Codigo: String; Canvas: TCanvas);
  public
    { Public declarations }
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}

{ TForm1 }

procedure TForm1.bitbtnsairClick(Sender: TObject);
begin
PageControl1.ActivePage := lista;
end;

procedure TForm1.btngerarcodbarraClick(Sender: TObject);
var
cod_ficha : string;
cod_random: double;
begin
 cod_random := 0;
 cod_ficha := '';
 cod_random := 1 + Random(10000000000);
 cod_ficha := floattostr(cod_random);

 edtcodarra.Text := cod_ficha;
 GerarCodigo(edtcodarra.Text, imgcodbarra.Canvas);

 //1234567891234567891234567
end;

procedure TForm1.btnSalvarClick(Sender: TObject);
var
codigo : integer;
begin
qryPVFicha.Close;
qryPVFicha.Open();

codigo := qryPVFicha.FieldByName('codigo').Value + 1;

   qryinsereficha.Insert;
   qryinserefichaCODIGO.Value := codigo;
   qryinserefichaCOD_FICHA.Value :=  edtcodarra.Text;
   qryinserefichaCODBARRAPV.Assign(imgcodbarra.Picture.Graphic);

   qryinsereficha.Post;

   showmessage('Ficha Criada com Sucesso!');
   qryPVFicha.Close;
   qryPVFicha.SQL.Text := ' select * from prevendaficha where codigo = '+inttostr(codigo);
   qrypvficha.Open();

   try
    frxReport1.ShowReport();
   finally
     bitbtnsairClick(self);
   end;


end;

procedure TForm1.FormCreate(Sender: TObject);
begin
qryinsereficha.CreateDataSet;
end;

procedure TForm1.GerarCodigo(Codigo: String; Canvas: TCanvas);

const
digitos : array['0'..'9'] of string[5]= ('00110', '10001', '01001', '11000',
'00101', '10100', '01100', '00011', '10010', '01010');
var s : string;
i, j, x, t : Integer;
begin
// Gerar o valor para desenhar o c鏚igo de barras
// Caracter de in獳io
s := '0000';
for i := 1 to length(codigo) div 2 do
for j := 1 to 5 do
s := s + Copy(Digitos[codigo[i * 2 - 1]], j, 1) + Copy(Digitos[codigo[i * 2]], j, 1);
// Caracter de fim
s := s + '100';
// Desenhar em um objeto canvas
// Configurar os par滵etros iniciais
x := 0;
// Pintar o fundo do c鏚igo de branco
Canvas.Brush.Color := clWhite;
Canvas.Pen.Color := clWhite;
Canvas.Rectangle(0,0, 2000, 79);
// Definir as cores da caneta
Canvas.Brush.Color := clBlack;
Canvas.Pen.Color := clBlack;
// Escrever o c鏚igo de barras no canvas
for i := 1 to length(s) do
begin
// Definir a espessura da barra
t := strToInt(s[i]) * 2 + 1;
// Imprimir apenas barra sim barra n緌 (preto/branco - intercalado);
if i mod 2 = 1 then
Canvas.Rectangle(x, 0, x + t, 79);
// Passar para a pr闛ima barra
x := x + t;
end;
end;


end.
