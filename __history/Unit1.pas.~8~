begin

  var Caminho:string;
  Caminho:=Extractfilepath(Application.ExeName)+'database.ini';
  if not FileExists(caminho) then
     Caminho:='C:\ALQUIMIA\database.ini';

  ini := TIniFile.Create(Caminho);
  try
    DataBaseVer := ini.ReadString('Banco','Database','');
    if length(trim(DataBaseVer)) = 0 then
    begin
      DataBaseVer := ini.ReadString('Banco','Database','');
      if length(trim(DataBaseVer)) = 0 then
      begin
        ShowMessage('Năo Foi Cadastro o Caminho do Banco de Dados!');
        Application.Terminate;
      end;
      host        := ini.ReadString('Banco','host','');
      Databasever := ini.ReadString('Banco','Database','');
      Usuario     := Crypt('D',ini.ReadString('Banco','Usuario',''),'SYSDBA');
      UsuSenha    := Crypt('D',ini.ReadString('Banco','Senha',''),'SYSDBA');
    end
    else
    begin
      host        := ini.ReadString('Banco','host','');
      Databasever := ini.ReadString('Banco','Database','');
      Usuario     := Crypt('D',ini.ReadString('Banco','Usuario',''),'SYSDBA');
      UsuSenha    := Crypt('D',ini.ReadString('Banco','Senha',''),'SYSDBA');
    end;


    AlquimiaConection.Params.Values['server']    :=   host;
    alquimiaconection.Params.Values['user_name'] :=   Usuario;
    alquimiaconection.Params.Values['password']  :=   UsuSenha;
    AlquimiaConection.Params.Values['database']  :=   DataBaseVer;


    try
       alquimiaconection.Connected := true;
    except
       on e:exception do
          begin
             ShowMessage('Falha na Conexăo Banco:'+sLineBreak+sLineBreak+
                          e.Message+sLineBreak+sLineBreak+
                          'Informe ao Suporte Alquimia!');
             Application.Terminate;
             exit;
          end;
    end;
  except
    On e:Exception do
    begin
      Application.ShowException(e);
      Application.Terminate;
    end;
  end;
  ini.free;


end;
procedure TForm1.TestarCorrecaoXML(const CaminhoXMLOriginal: string);
var
  i, j: Integer;
  DuplicadoEncontrado: Boolean;
  CaminhoXMLNovo: string;
begin
  // 1. Limpa o componente e carrega o seu XML lá do Downloads
  ACBrNFe1.NotasFiscais.Clear;
  ACBrNFe1.NotasFiscais.LoadFromFile(CaminhoXMLOriginal);

  // 2. Lógica de remoçăo de itens duplicados (varrendo de trás para frente)
  if ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count > 1 then
  begin
    for i := ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 downto 1 do
    begin
      DuplicadoEncontrado := False;

      // Compara o item atual (i) com os itens anteriores (j)
      for j := i - 1 downto 0 do
      begin
        // Critério de duplicidade: Mesmo código, quantidade, valor e desconto
        if (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.cProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.cProd) and
           (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.qCom  = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.qCom) and
           (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vProd) and
           (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vDesc) then
        begin
          DuplicadoEncontrado := True;
          Break;
        end;
      end;

      // Se encontrou a duplicidade, elimina o item excedente da lista
      if DuplicadoEncontrado then
      begin
        ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Delete(i);
      end;
    end;
  end;

  // 3. Reorganiza o sequencial dos itens de forma manual (.Prod.nItem)
  if ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count > 0 then
  begin
    for i := 0 to ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 do
    begin
      ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.nItem := i + 1;
    end;
  end;

  // === REGERA O XML BASEADO NA MUDANÇA DA MEMÓRIA ===
  ACBrNFe1.NotasFiscais.GerarNFe;

  // 4. Define o caminho de saída direto na sua pasta de Downloads
  CaminhoXMLNovo := 'C:\Users\Vicente\Downloads\Nota_Corrigida.xml';

  // 5. Grava o arquivo físico final corrigido
  ACBrNFe1.NotasFiscais.Items[0].GravarXML(CaminhoXMLNovo, '');

  ShowMessage('Teste concluído! O arquivo corrigido foi gerado em:' + sLineBreak + CaminhoXMLNovo);
end;
procedure TForm1.VerificarDuplicidadeETotalXML(
  const CaminhoXMLOriginal: string);
var
  i, j: Integer;
  DuplicadoEncontrado: Boolean;
  TotalItensSemDuplicidade: Double;
  TotalItensComDuplicidade: Double;
  TotalNotaGravado: Double;
  QtdDuplicados: Integer;
  ValorItem: Double;
begin
  // 1. Limpa o componente e carrega o XML apenas para leitura/análise
  ACBrNFe1.NotasFiscais.Clear;
  ACBrNFe1.NotasFiscais.LoadFromFile(CaminhoXMLOriginal);

  QtdDuplicados := 0;
  TotalItensComDuplicidade := 0;
  TotalItensSemDuplicidade := 0;

  // 2. Pega o valor TOTAL geral que a SEFAZ gravou na nota (vNF)
  TotalNotaGravado := ACBrNFe1.NotasFiscais.Items[0].NFe.Total.ICMSTot.vNF;

  // 3. Varre a lista para calcular os totais e identificar duplicados
  for i := 0 to ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 do
  begin
    // Calcula o valor líquido do item atual (Valor do Produto - Desconto)
    ValorItem := ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd -
                 ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc;

    // O total bruto com a duplicidade vai somando tudo o que está no arquivo
    TotalItensComDuplicidade := TotalItensComDuplicidade + ValorItem;

    // Verifica se este item específico é uma duplicidade de algum item ANTERIOR
    DuplicadoEncontrado := False;
    if i > 0 then
    begin
      for j := i - 1 downto 0 do
      begin
        if (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.cProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.cProd) and
           (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.qCom  = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.qCom) and
           (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vProd) and
           (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vDesc) then
        begin
          DuplicadoEncontrado := True;
          Break;
        end;
      end;
    end;

    // Se NĂO for duplicado, ele entra na soma do que seria o correto
    if not DuplicadoEncontrado then
    begin
      TotalItensSemDuplicidade := TotalItensSemDuplicidade + ValorItem;
    end
    else
    begin
      Inc(QtdDuplicados);
    end;
  end;

  // 4. Exibe o diagnóstico na tela comparando com o Total Gravado (vNF)
  if QtdDuplicados > 0 then
  begin
    // CASO 1: O total da nota bate com os itens sem a duplicidade (O total está certo, os itens estăo errados)
    if Abs(TotalItensSemDuplicidade - TotalNotaGravado) < 0.01 then
    begin
      ShowMessage(Format('ANÁLISE DA NOTA:' + sLineBreak +
                         '- Itens Duplicados: SIM (%d item/ns)' + sLineBreak +
                         '- Valor Total da Nota (vNF): R$ %.2f' + sLineBreak +
                         'STATUS: O valor total da nota já está CORRETO. Ele reflete a nota SEM a duplicidade.',
                         [QtdDuplicados, TotalNotaGravado]));
    end
    // CASO 2: O total da nota foi inflado e bate com a duplicidade somada (Tudo errado)
    else if Abs(TotalItensComDuplicidade - TotalNotaGravado) < 0.01 then
    begin
      ShowMessage(Format('ANÁLISE DA NOTA:' + sLineBreak +
                         '- Itens Duplicados: SIM (%d item/ns)' + sLineBreak +
                         '- Valor Total da Nota (vNF): R$ %.2f' + sLineBreak +
                         'STATUS: O valor total da nota está INCORRETO. Ele incluiu o valor dos itens duplicados.',
                         [QtdDuplicados, TotalNotaGravado]));
    end
    // CASO 3: Diferença louca que năo bate com nenhum dos dois cenários
    else
    begin
      ShowMessage(Format('ANÁLISE DA NOTA:' + sLineBreak +
                         '- Itens Duplicados: SIM (%d item/ns)' + sLineBreak +
                         '- Valor Total da Nota (vNF): R$ %.2f' + sLineBreak +
                         '- Esperado sem duplicados: R$ %.2f' + sLineBreak +
                         'STATUS: Diferença desconhecida. Os valores năo batem.',
                         [QtdDuplicados, TotalNotaGravado, TotalItensSemDuplicidade]));
    end;
  end
  else
  begin
    ShowMessage('ANÁLISE DA NOTA:' + sLineBreak +
                'Nenhum item duplicado foi detectado neste XML.');
  end;
end;

end.
