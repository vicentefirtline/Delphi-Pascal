procedure TForm1.CorrigirEQuarentenarNotasBanco;
var
  i, j: Integer;
  DuplicadoEncontrado: Boolean;
  HouveDuplicidadeEstrutural: Boolean;
  PastaDesktop: string;
  CaminhoXMLDuplicado: string;
  CaminhoXMLCorrigido: string;
  NomeBase: string;

  // Variáveis para a validaçăo matemática correta
  SomaMatematicaItens: Double;
  TotalNotavNF: Double;
  NovoTotalProdutos: Double;
  NovoTotalDescontos: Double;
begin
  // 1. Configura a query principal com o filtro de data antes do laço
  qryvendas.Close;
  qryvendas.SQL.Text := 'select ven_Numero from vendas where ven_data_venda between :data_inicial and :data_final';

  qryvendas.ParamByName('data_inicial').AsDateTime := dtpInicial.Date;
  qryvendas.ParamByName('data_final').AsDateTime   := dtpFinal.Date;
  qryvendas.Open;

  if qryvendas.Eof then
  begin
    ShowMessage('Nenhuma venda encontrada no período selecionado.');
    Exit;
  end;

  PastaDesktop := GetEnvironmentVariable('USERPROFILE') + '\Desktop\Notas_Corrigidas_' + FormatDateTime('yyyy-mm-dd', Date);

  if not DirectoryExists(PastaDesktop) then
    ForceDirectories(PastaDesktop);

  // 3. LAÇO MAIOR: Varre as vendas filtradas pelas datas
  while not qryvendas.Eof do
  begin
    qryconsultaxml.Close;
    qryconsultaxml.ParamByName('VEN_NUMERO').Value := qryvendas.FieldByName('ven_Numero').Value;
    qryconsultaxml.Open;

    if not qryconsultaxml.Eof then
    begin
      ACBrNFe1.NotasFiscais.Clear;
      ACBrNFe1.NotasFiscais.LoadFromString(qryconsultaxml.FieldByName('xml').AsString);

      HouveDuplicidadeEstrutural := False;
      SomaMatematicaItens := 0;
      TotalNotavNF := ACBrNFe1.NotasFiscais.Items[0].NFe.Total.ICMSTot.vNF;

      // PASSO A: Primeiro, vamos checar se existe a duplicidade de estrutura no XML
      if ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count > 1 then
      begin
        for i := ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 downto 1 do
        begin
          for j := i - 1 downto 0 do
          begin
            if (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.cProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.cProd) and
               (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.qCom  = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.qCom) and
               (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vProd) and
               (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vDesc) then
            begin
              HouveDuplicidadeEstrutural := True;
              Break;
            end;
          end;
          if HouveDuplicidadeEstrutural then Break;
        end;
      end;

      // PASSO B: Se tem duplicidade na estrutura, fazemos a PROVA REAL MATEMÁTICA
      if HouveDuplicidadeEstrutural then
      begin
        // Soma a matemática de TODOS os itens do XML atual (vProd - vDesc)
        for i := 0 to ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 do
        begin
          SomaMatematicaItens := SomaMatematicaItens +
            (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd -
             ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc);
        end;

        // SE A SOMA DE TUDO NĂO BATER COM O vNF, ATENÇĂO: COINCIDE COM O BUG!
        // Significa que a nota está quebrada e precisa de correçăo física.
        if Abs(SomaMatematicaItens - TotalNotavNF) > 0.01 then
        begin
          NomeBase := ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID;

          // Salva o XML problemático original na pasta _DUPLICADA
          CaminhoXMLDuplicado := TPath.Combine(PastaDesktop, NomeBase + '_DUPLICADA.xml');
          ACBrNFe1.NotasFiscais.Items[0].GravarXML(CaminhoXMLDuplicado, '');

          // Executa o corte físico do item clonado na memória
          for i := ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 downto 1 do
          begin
            DuplicadoEncontrado := False;
            for j := i - 1 downto 0 do
            begin
              if (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.cProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.cProd) and
                 (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.qCom  = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.qCom) and
                 (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vProd) and
                 (ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc = ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[j].Prod.vDesc) then
              begin
                DuplicadoEncontrado := True;
                Break;
              end;
            end;
            if DuplicadoEncontrado then
            begin
              ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Delete(i);
            end;
          end;

          // Zera acumuladores para recalcular o cabeçalho com o que sobrou de fato
          NovoTotalProdutos := 0;
          NovoTotalDescontos := 0;

          // Organiza os índices nItem dos produtos legítimos e soma os novos totais
          for i := 0 to ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Count - 1 do
          begin
            ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.nItem := i + 1;
            NovoTotalProdutos := NovoTotalProdutos + ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vProd;
            NovoTotalDescontos := NovoTotalDescontos + ACBrNFe1.NotasFiscais.Items[0].NFe.Det.Items[i].Prod.vDesc;
          end;

          // Força os novos totais corrigidos no cabeçalho
          ACBrNFe1.NotasFiscais.Items[0].NFe.Total.ICMSTot.vProd := NovoTotalProdutos;
          ACBrNFe1.NotasFiscais.Items[0].NFe.Total.ICMSTot.vDesc := NovoTotalDescontos;
          ACBrNFe1.NotasFiscais.Items[0].NFe.Total.ICMSTot.vNF   := NovoTotalProdutos - NovoTotalDescontos;

          // Reconstrói o XML final limpo
          ACBrNFe1.NotasFiscais.GerarNFe;

          // Salva a versăo corrigida
          CaminhoXMLCorrigido := TPath.Combine(PastaDesktop, NomeBase + '.xml');
          ACBrNFe1.NotasFiscais.Items[0].GravarXML(CaminhoXMLCorrigido, '');
        end;
      end;
    end;

    qryvendas.Next;
  end;

  ShowMessage('Processamento concluído! Apenas as notas com divergęncias reais foram exportadas.');
end;

function TForm1.Crypt(Action, Src, Key: String): String;
var
   KeyLen    : Integer;
   KeyPos    : Integer;
   offset    : Integer;
   dest      : string;
   SrcPos    : Integer;
   SrcAsc    : Integer;
   TmpSrcAsc : Integer;
   Range     : Integer;
   Men       : Boolean;
begin
   try
     dest:='';
     KeyLen:=Length(Key);
     KeyPos:=0;
     SrcPos:=0;
     SrcAsc:=0;
     Range:=256;
     if Action = UpperCase('E') then
     begin
          Randomize;
          offset:=Random(Range);
          dest:=format('%1.2x',[offset]);
          for SrcPos := 1 to Length(Src) do
          begin
               SrcAsc:=(Ord(Src[SrcPos]) + offset) MOD 255;
               if KeyPos < KeyLen then KeyPos:= KeyPos + 1 else KeyPos:=1;
               SrcAsc:= SrcAsc xor Ord(Key[KeyPos]);
               dest:=dest + format('%1.2x',[SrcAsc]);
               offset:=SrcAsc;
          end;
     end;
     if Action = UpperCase('D') then
     begin
          offset:=StrToInt('$'+ copy(src,1,2));
          SrcPos:=3;
          repeat
                SrcAsc:=StrToInt('$'+ copy(src,SrcPos,2));
                if KeyPos < KeyLen Then KeyPos := KeyPos + 1 else KeyPos := 1;
                TmpSrcAsc := SrcAsc xor Ord(Key[KeyPos]);
                if TmpSrcAsc <= offset then
                     TmpSrcAsc := 255 + TmpSrcAsc - offset
                else
                     TmpSrcAsc := TmpSrcAsc - offset;
                dest := dest + chr(TmpSrcAsc);
                offset:=srcAsc;
                SrcPos:=SrcPos + 2;
          until SrcPos >= Length(Src);
     end;
     Crypt:=dest;
     except
     DeleteFile(ExtractFilePath(Application.ExeName)+'PARAMETRO.INI');
     if Men=False then
        begin
           Men:=True;
           ShowMessage('ERRO LENDO CONFIGURAÇŐES DO BANCO DE DADOS!'+#13+'ENTRE NOVAMENTE NO SISTEMA PARA EFETUAR AS CONFIGURAÇŐES.!');
        end;
     end;

end;

procedure TForm1.FormShow(Sender: TObject);
